# PostgreSQL（order と別データベース名を推奨: daiko）
DATABASE_URL="postgresql://user:pass@localhost:5432/daiko?schema=public"
JWT_SECRET="change-me-to-long-random-string"
PORT=3001
# ログイン不要のデモ入口（本番ではデモ専用テナント＋ユーザーを用意したうえで設定）
# DAIKO_DEMO_TENANT_SLUG="demo-shop"
# DAIKO_DEMO_USER_EMAIL="demo-viewer@example.com"
# 書類 PDF 用（本番では scripts/ensure-chromium-env.sh が .env に追記することもあります）
# CHROMIUM_EXECUTABLE=/usr/bin/google-chrome-stable
# または: /usr/bin/chromium や /usr/bin/chromium-browser

# プラットフォーム管理（LP問い合わせ・全テナント）— カンマ区切りメール
DAIKO_PLATFORM_ADMIN_EMAILS="yagi@harunoyukoto.com"
# LP問い合わせの通知先（未設定時は PLATFORM_ADMIN_EMAILS と同じ）
DAIKO_INQUIRY_NOTIFY_TO="yagi@harunoyukoto.com"
# SMTP（未設定時はDB保存のみ・コンソールにログ）
# ホスト・認証情報は利用するメールサービスに合わせて差し替えてください
DAIKO_SMTP_HOST="mail.harunoyukoto.com"
DAIKO_SMTP_PORT=465
DAIKO_SMTP_SECURE=1
DAIKO_SMTP_USER="yagi@harunoyukoto.com"
DAIKO_SMTP_PASS="your_smtp_password"
DAIKO_SMTP_FROM="yagi@harunoyukoto.com"

# Stripe（課金・サブスクリプション）— シークレットキーはリポジトリにコミットしない
STRIPE_SECRET_KEY="sk_test_..."
# Stripe Dashboard → Webhooks → 署名シークレット（whsec_...）
STRIPE_WEBHOOK_SECRET="whsec_..."
# 月額・年額 Price ID（Stripe Dashboard のテスト／本番で差し替え）
DAIKO_STRIPE_PRICE_MONTHLY="price_..."
DAIKO_STRIPE_PRICE_YEARLY="price_..."
# Checkout 完了・キャンセル後のリダイレクト（ローカル検証時は http://127.0.0.1:5174 等に変更可）
DAIKO_STRIPE_CHECKOUT_SUCCESS_URL="https://daiko.harunoyukoto.jp/app/billing?session_id={CHECKOUT_SESSION_ID}"
DAIKO_STRIPE_CHECKOUT_CANCEL_URL="https://daiko.harunoyukoto.jp/app/billing"
