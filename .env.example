# PostgreSQL（order と別データベース名を推奨: daiko）
DATABASE_URL="postgresql://user:pass@localhost:5432/daiko?schema=public"
JWT_SECRET="change-me-to-long-random-string"
PORT=3001
# ログイン不要のデモ入口（本番ではデモ専用テナント＋ユーザーを用意したうえで設定）
# DAIKO_DEMO_TENANT_SLUG="demo-shop"
# DAIKO_DEMO_USER_EMAIL="demo-viewer@example.com"
# 書類 PDF 用（本番では scripts/ensure-chromium-env.sh が .env に追記することもあります）
# CHROMIUM_EXECUTABLE=/usr/bin/google-chrome-stable
# または: /usr/bin/chromium や /usr/bin/chromium-browser
