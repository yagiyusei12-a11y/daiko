generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  STANDARD
  PREMIUM
}

enum CompensationType {
  HOURLY_ONLY
  COMMISSION_ONLY
  HOURLY_AND_COMMISSION
}

enum EmployeeStatus {
  ACTIVE
  RETIRED
}

enum PayrollRunStatus {
  DRAFT
  LOCKED
}

enum TripRole {
  MAIN_DRIVER
  PARTNER_DRIVER
}

enum TariffDistanceMode {
  INITIAL_ADD
  SEGMENTS_ONLY
  TIERED_ADD
}

enum TripPassengerKind {
  GENERAL
  MEMBER
}

enum TimeCardPunchKind {
  CLOCK_IN
  CLOCK_OUT
  BREAK_START
  BREAK_END
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("Asia/Tokyo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings            TenantSettings?
  subscriptions       Subscription[]
  users               User[]
  roles               Role[]
  employees           Employee[]
  vehicles            Vehicle[]
  tariffPlans         TariffPlan[]
  dailyReports        DailyReport[]
  timePunches         TimePunch[]
  alcoholChecks       AlcoholCheck[]
  payrollRuns         PayrollRun[]
  refreshTokens       RefreshToken[]
  auditEvents         AuditEvent[]
  legalRegisterStubs  LegalRegisterStub[]
  complaintLedgers    ComplaintLedger[]
  guidanceSessions    GuidanceSession[]
  legalChangeNotices  LegalChangeNotice[]
  customers           Customer[]
  referralSources     ReferralSource[]
  dispatchReservations DispatchReservation[]
  accountsReceivableEntries AccountsReceivableEntry[]
  demoSeedBatches     DemoSeedBatch[]
  shiftApplications   ShiftApplication[]
  confirmedShiftDays  ConfirmedShiftDay[]
  timeCardPunches     TimeCardPunch[]
  vehicleOdometerLogs VehicleOdometerLog[]
  lineChannels        TenantLineChannel[]
}

/// デモ用サンプル投入のバッチ（payload に作成した主キー一覧を保持し、削除時に利用）
model DemoSeedBatch {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

/// 従業員ごとの月単位シフト申請（日付キー yyyy-MM-dd → 開始・終了時刻 HH:mm）
model ShiftApplication {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  yearMonth  String
  daysJson   Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, yearMonth])
  @@index([tenantId, yearMonth])
}

model TenantSettings {
  tenantId String @id
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// 0–23: この時刻までは前日の事業日に含める
  businessDayRollHour Int @default(4)

  /// プラン由来の機能フラグ（JSON）。例: { "receiptEnabled": true, "paymentMethodsEnabled": false }
  featureFlags Json @default("{}")

  /// 任意の拡張（領収書・決済手段など）
  customJson Json @default("{}")

  /// 法定9帳票向けの共通情報（customJson ではなく構造化列で管理）
  legalTradeName                  String?
  legalRepresentativeName         String?
  legalBusinessAddress            String?
  /// 会社情報（設定タブ）: 郵便番号・都道府県・番地以降。legalBusinessAddress と併用可。
  legalPostalCode                 String?
  legalPrefecture                 String?
  legalStreetAddress              String?
  legalPhone                      String?
  legalPublicSafetyCommission     String?
  legalCertificationNumber        String?
  legalCertificationDate          DateTime?
  legalMainOfficeName             String?
  legalMainOfficeAddress          String?
  legalSafetyManagerName          String?
  legalAlcoholDetectorModel       String?
  legalAlcoholInspectionDone      Boolean?
  legalAlcoholInspectionDate      DateTime?
  legalMutualAidOrganizationName  String?
  legalMutualAidContractFrom      DateTime?
  legalMutualAidContractTo        DateTime?
  legalBodilyCoverage             String?
  legalPropertyCoverage           String?
  legalVehicleCoverageLimitManYen String?
}

model Subscription {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planTier  PlanTier
  validFrom DateTime  @default(now())
  validTo   DateTime?
  createdAt DateTime  @default(now())
}

model Role {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  permissions Json       @default("[]")
  userRoles   UserRole[]

  @@unique([tenantId, name])
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  displayName  String?
  /// 勤怠・酒気・スタッフ日報スコープ用（ログイン＝この従業員）
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId, employeeId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model Employee {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  familyName  String
  givenName   String
  furigana    String?
  address     String?
  /// 従事者名簿用（性別・生年月日・連絡先・免許・緊急連絡先など）JSON
  registerExtension Json @default("{}")
  /// 従業員マスタ: 管理者
  adminMaster          Boolean @default(false)
  /// 従業員マスタ: 安全運転管理者
  safetyDrivingManager Boolean @default(false)
  status      EmployeeStatus @default(ACTIVE)
  retiredAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  compensationPeriods EmployeeCompensationPeriod[]
  timePunches         TimePunch[]
  alcoholChecks       AlcoholCheck[]
  payrollLines           PayrollLine[]
  dailyReportsAsMain    DailyReport[] @relation("DailyReportMain")
  dailyReportsAsPartner DailyReport[] @relation("DailyReportPartner")
  complaintRowsAsDriver    ComplaintLedger[]
  guidanceAttendances      GuidanceAttendee[]
  linkedUsers              User[]
  shiftApplications        ShiftApplication[]
  confirmedShiftDays       ConfirmedShiftDay[]
  timeCardPunches          TimeCardPunch[]
  dispatchReservationsAsDriver DispatchReservation[] @relation("DispatchReservationDriver")

  @@index([tenantId, status])
}

/// シフト調整で確定した日単位の勤務（担当業務は JSON 文字列配列）
model ConfirmedShiftDay {
  id           String   @id @default(cuid())
  tenantId     String
  employeeId   String
  businessDate String
  startTime    String
  endTime      String
  dutiesJson   Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, businessDate])
  @@index([tenantId, businessDate])
}

/// テナントと公式 LINE（LIFF / Webhook 用）。lineChannelId は id_token の aud と突合せる。
model TenantLineChannel {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// LINE Login チャネル ID（LIFF の id_token の aud）
  lineChannelId     String
  /// Messaging API チャネルシークレット等（Webhook 検証・将来拡張用）
  lineChannelSecret String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, lineChannelId])
  @@index([lineChannelId])
}

/// タイムカード打刻（出勤・退勤・休憩はイベントとして複数行で保持）
model TimeCardPunch {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  businessDate String
  kind         TimeCardPunchKind
  punchedAt    DateTime         @default(now())
  /// 出勤（CLOCK_IN）時のアルコールチェック記録
  alcoholCheckJson Json?

  @@index([tenantId, businessDate, employeeId])
}

model EmployeeCompensationPeriod {
  id             String            @id @default(cuid())
  employeeId     String
  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  validFrom      DateTime
  validTo        DateTime?
  compensationType CompensationType
  baseHourlyYen  Int               @default(0)
  commissionMainRateBps    Int     @default(0)
  commissionPartnerRateBps Int     @default(0)
  createdAt      DateTime          @default(now())

  @@index([employeeId, validFrom])
}

model Vehicle {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label     String
  plate     String?
  legalCoverageStartOn DateTime?
  /// 随伴車詳細（ナンバー分割・車検・任意保険など）JSON
  detailJson Json @default("{}")
  active    Boolean  @default(true)
  /// 日報・設定から更新する現在ODO（表示単位は日報のメーター／随伴ODOと揃えた整数）
  currentOdometer Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyReportsMain   DailyReport[] @relation("DailyReportMainVehicle")
  dailyReportsEscort DailyReport[] @relation("DailyReportEscortVehicle")
  dispatchReservations DispatchReservation[]
  odometerLogs       VehicleOdometerLog[]

  @@index([tenantId, active])
}

model VehicleOdometerLog {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  value         Int
  /// DAILY_REPORT | SETTINGS
  source        String
  dailyReportId String?
  dailyReport   DailyReport? @relation(fields: [dailyReportId], references: [id], onDelete: SetNull)
  businessDate  String?
  createdAt     DateTime @default(now())

  @@index([tenantId, vehicleId, createdAt])
  @@index([tenantId])
}

model TariffPlan {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions TariffPlanVersion[]

  @@index([tenantId])
}

model TariffPlanVersion {
  id        String   @id @default(cuid())
  planId    String
  plan      TariffPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  version   Int
  validFrom DateTime @default(now())
  validTo   DateTime?

  /// 初乗り: 距離m, 金額円
  initialDistanceM Int @default(0)
  initialFareYen   Int @default(0)
  /// 加算単位（この距離ごとに addFareYen）
  addUnitDistanceM Int @default(0)
  addFareYen       Int @default(0)
  waitingFareYenPerMin Int @default(0)

  /// INITIAL_ADD: 初乗り＋単一加算（従来）。SEGMENTS_ONLY: セグメント表のみ。TIERED_ADD: 初乗り＋多段距離加算（TariffDistanceTier）。
  distanceMode TariffDistanceMode @default(INITIAL_ADD)
  /// 待機課金ルール（linear / block / grace_flat_then_linear）。従来列 waitingFareYenPerMin と併用し、保存時は同期可能。
  waitingRuleJson Json @default("{}")
  perViaStopYen            Int @default(0)
  cancellationFeeYen     Int @default(0)
  nightSurchargeBps        Int @default(0)
  leftHandSurchargeBps     Int @default(0)
  /// 左ハンドル車の定額（便フラグ applyLeftHandSurchargeFlat）。％は leftHandSurchargeBps。
  leftHandSurchargeFlatYen Int @default(0)
  /// 深夜等の定額（便フラグ applyNightSurchargeFlat で加算）。距離運賃への％は nightSurchargeBps。
  nightSurchargeFlatYen    Int @default(0)
  /// さらに遅い時間帯の定額（便 applyLateNightFlatYen）
  lateNightFlatYen         Int @default(0)
  /// 早朝帯1の定額（便 applyEarlyMorningFlatYen）
  earlyMorningFlatYen      Int @default(0)
  /// 早朝帯2の定額（便 applyEarlyRushFlatYen）
  earlyRushFlatYen         Int @default(0)
  /// 迎車: 基準地点からの距離帯ごとの円。`pickup-pricing` の Zod 形式。
  pickupRuleJson           Json @default("[]")
  /// この距離（m）以上で距離運賃に distanceDiscountBps を1回適用。null で割引なし。
  distanceDiscountFromM    Int?
  /// 距離割引（例: -1000 で約10%引き）。distanceDiscountFromM とセットで使用。
  distanceDiscountBps      Int @default(0)
  /// 帳票・メモ用の自由記述
  notes                    String?

  segments       TariffSegment[]
  distanceTiers  TariffDistanceTier[]
  tripLegs       TripLeg[]
  defaultForCustomers Customer[] @relation("CustomerDefaultTariff")

  @@unique([planId, version])
}

/// 多段距離加算（absolute fromM 以上、untilM 未満の区間で stepM ごとに addYenPerStep）
model TariffDistanceTier {
  id            String @id @default(cuid())
  versionId     String
  version       TariffPlanVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  sortOrder     Int    @default(0)
  fromM         Int
  untilM        Int?
  stepM         Int
  addYenPerStep Int

  @@index([versionId, sortOrder])
}

/// 距離帯の上書き（任意・将来拡張）
model TariffSegment {
  id         String @id @default(cuid())
  versionId  String
  version    TariffPlanVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  fromM      Int
  toM        Int
  fareYen    Int
  /// null のとき会員料金は一般と同額（未使用扱い）
  fareMemberYen Int?
}

/// 顧客名簿（運行で選択して出発地・目的地・特別料金に利用）
model Customer {
  id                     String             @id @default(cuid())
  tenantId               String
  tenant                 Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  displayName            String
  phone                  String?
  defaultOrigin          String             @default("")
  defaultDestination     String             @default("")
  defaultTariffVersionId String?
  defaultTariffVersion   TariffPlanVersion? @relation("CustomerDefaultTariff", fields: [defaultTariffVersionId], references: [id], onDelete: SetNull)
  specialFareYen         Int?
  notes                  String?
  archivedAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  trips                  TripLeg[]

  @@index([tenantId, displayName])
}

/// 飲食店など紹介元
model ReferralSource {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  memo        String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  trips       TripLeg[]

  @@index([tenantId, name])
}

model DailyReport {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessDate      String
  vehicleId         String?
  vehicle           Vehicle?  @relation("DailyReportMainVehicle", fields: [vehicleId], references: [id], onDelete: Restrict)
  mainEmployeeId    String
  mainEmployee      Employee  @relation("DailyReportMain", fields: [mainEmployeeId], references: [id], onDelete: Restrict)
  partnerEmployeeId String?
  partnerEmployee   Employee? @relation("DailyReportPartner", fields: [partnerEmployeeId], references: [id], onDelete: SetNull)
  /// 勤務セッション: 随伴車（客車は vehicleId）
  escortVehicleId      String?
  escortVehicle        Vehicle? @relation("DailyReportEscortVehicle", fields: [escortVehicleId], references: [id], onDelete: SetNull)
  /// メーター型のODO（メーカー距離）km 等、運用で整数単位を統一
  escortOdometerStartM Int?
  escortOdometerEndM   Int?
  meterStart        Int
  meterEnd          Int
  dutyStartAt       DateTime?
  dutyEndAt         DateTime?
  breakTaken        Boolean   @default(false)
  breakStartAt      DateTime?
  breakEndAt        DateTime?
  breakLocation     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  /// 日報単位の決済内訳（円）
  paymentCashYen       Int @default(0)
  /// 現金のうち領収書を発行しなかった金額（0〜paymentCashYen）
  paymentCashNoReceiptYen Int @default(0)
  paymentCardYen       Int @default(0)
  paymentPayPayYen     Int @default(0)
  paymentReceivableYen Int @default(0)

  trips               TripLeg[]
  vehicleOdometerLogs VehicleOdometerLog[]

  @@index([tenantId, businessDate])
}

model TripLeg {
  id               String   @id @default(cuid())
  dailyReportId    String
  dailyReport      DailyReport @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  clientName       String
  charterVehicleNo String?
  origin           String
  destination      String
  viaNote          String?
  /// 経由地名の配列（JSON: string[]）。帳票互換のため viaNote とも同期可能
  viaStopsJson     Json     @default("[]")
  departedAt       DateTime
  arrivedAt        DateTime
  distanceM        Int
  /// 待機時間（分）。waitingRuleJson と waitingFareYenPerMin に基づき待機運賃を計算
  waitingMinutes   Int      @default(0)
  tariffVersionId  String?
  tariffVersion    TariffPlanVersion? @relation(fields: [tariffVersionId], references: [id], onDelete: SetNull)
  fareYen          Int      @default(0)
  role             TripRole @default(MAIN_DRIVER)
  passengerKind           TripPassengerKind @default(GENERAL)
  viaStopCount            Int               @default(0)
  applyNightSurcharge     Boolean           @default(false)
  applyLeftHandSurcharge  Boolean           @default(false)
  applyLeftHandSurchargeFlat Boolean        @default(false)
  /// 基準地点からの迎車距離（m）。版の pickupRuleJson で円に換算。
  pickupFromBaseM                Int?
  applyNightSurchargeFlat        Boolean @default(false)
  applyLateNightFlatYen          Boolean @default(false)
  applyEarlyMorningFlatYen       Boolean @default(false)
  applyEarlyRushFlatYen          Boolean @default(false)
  createdAt        DateTime @default(now())

  /// 駐車場等の立替金（円）。運賃・売上集計とは別扱い
  parkingAdvanceYen Int @default(0)
  /// 運行区間のメーター開始（任意・記録用、メートル単位の整数など運用で統一）
  tripMeterStartM Int?
  /// 運行区間のメーター終了（任意）
  tripMeterEndM Int?

  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  referralSourceId String?
  referralSource   ReferralSource? @relation(fields: [referralSourceId], references: [id], onDelete: SetNull)
  /// 手動で上書きする運賃（円）。null のときは料金版から計算した fareYen を使用。
  fareOverrideYen  Int?
  /// 公式帳票・税理士提出用 CSV から除外（データは保持。集計は用途に応じて全件／公式のみを API で切替）
  excludeFromOfficialPrint Boolean @default(false)

  /// 迎車・左ハンドル・外車・キャンセル等（設定の基本額をデフォルト表示）
  legSurchargesJson Json @default("{}")

  @@index([dailyReportId])
}

/// 配車・予約（ガント前段：一覧と CRUD）
model DispatchReservation {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicleId String?
  vehicle   Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  /// 運行予定の客車担当（確定シフトの客車と整合させる）
  driverEmployeeId String?
  driverEmployee     Employee? @relation("DispatchReservationDriver", fields: [driverEmployeeId], references: [id], onDelete: SetNull)
  title     String
  note      String?
  /// 客名・経路・車番など（運行予定フォーム）
  detailJson Json @default("{}")
  startsAt  DateTime
  endsAt    DateTime
  status    String    @default("CONFIRMED")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, startsAt])
  @@index([tenantId, driverEmployeeId])
}

/// 売掛（未回収金）メモ。回収で status を更新
model AccountsReceivableEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partyName   String
  amountYen   Int
  status      String   @default("OPEN")
  collectedAt DateTime?
  referenceNote String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model TimePunch {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  businessDate String
  clockInAt    DateTime
  clockOutAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([tenantId, businessDate, employeeId])
}

model AlcoholCheck {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  businessDate    String
  phase           String
  checkedAt       DateTime
  checkerName     String?
  checkMethod     String?
  checkMethodOther String?
  methodNote      String?
  detectorUsed    Boolean  @default(false)
  resultPositive  Boolean  @default(false)
  instructionNote String?
  otherNote       String?
  supervisorNote  String?
  createdAt       DateTime @default(now())

  @@index([tenantId, businessDate])
}

model PayrollRun {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodYm      String
  status        PayrollRunStatus  @default(DRAFT)
  poolRateBps   Int               @default(0)
  createdAt     DateTime          @default(now())
  lockedAt      DateTime?

  lines PayrollLine[]

  @@unique([tenantId, periodYm])
}

model PayrollLine {
  id            String     @id @default(cuid())
  runId         String
  run           PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  grossSalesYen Int        @default(0)
  hourlyYen     Int        @default(0)
  commissionYen Int        @default(0)
  poolYen       Int        @default(0)
  netPayYen     Int        @default(0)
  breakdownJson Json       @default("{}")

  @@unique([runId, employeeId])
}

model DocumentTemplate {
  id        String   @id @default(cuid())
  kind      String
  version   Int
  label     String
  htmlBody  String   @db.Text
  createdAt DateTime @default(now())

  @@unique([kind, version])
}

model AuditEvent {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  payload     Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
}

/// 法定系スタブ（苦情・指導・従事者名簿）のプレースホルダ行
model LegalRegisterStub {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  /// complaint | guidance | roster
  kind      String
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([tenantId, kind])
}

model ComplaintLedger {
  id                    String    @id @default(cuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  receivedAt            DateTime
  receivedBy            String?
  occurredOn            DateTime?
  placeOrSection        String?
  driverEmployeeId      String?
  driverEmployee        Employee? @relation(fields: [driverEmployeeId], references: [id], onDelete: SetNull)
  complainantName       String?
  complainantAddress    String?
  complainantContact    String?
  category              String?
  categoryOther         String?
  detail                String?
  causeAnalysis         String?
  rebuttal              String?
  correctiveAction      String?
  handlerName           String?
  completedOn           DateTime?
  representativeChecked Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId, receivedAt])
}

model GuidanceSession {
  id                    String             @id @default(cuid())
  tenantId              String
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  startedAt             DateTime
  endedAt               DateTime?
  location              String?
  instructorName        String?
  topicFeeCollection    Boolean            @default(false)
  topicTerms            Boolean            @default(false)
  topicConditionExplain Boolean            @default(false)
  topicMarking          Boolean            @default(false)
  topicRoadTransportLaw Boolean            @default(false)
  topicOther            String?
  topicOtherDetail      String?
  remarks               String?
  representativeChecked Boolean            @default(false)
  attendees             GuidanceAttendee[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([tenantId, startedAt])
}

model GuidanceAttendee {
  id                String          @id @default(cuid())
  guidanceSessionId String
  guidanceSession   GuidanceSession @relation(fields: [guidanceSessionId], references: [id], onDelete: Cascade)
  employeeId        String?
  employee          Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  attendeeName      String?
  createdAt         DateTime        @default(now())

  @@index([guidanceSessionId])
}

model LegalChangeNotice {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  changeType     String?
  submittedOn    DateTime?
  changedOn      DateTime?
  effectiveOn    DateTime?
  oldValue       String?
  newValue       String?
  reason         String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, createdAt])
}
