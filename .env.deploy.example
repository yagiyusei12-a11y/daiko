# Copy to daiko/.env.deploy (do not commit secrets)
DAIKO_VPS_HOST=133.18.141.239
DAIKO_VPS_USER=ubuntu
DAIKO_VPS_KEY=C:\path\to\ssh-key.pem
# VPS 上で daiko 専用リポジトリを clone したディレクトリ（clone ルート = アプリルート）
DAIKO_VPS_PATH=~/daiko
DAIKO_VPS_SERVICE=daiko-app

# ローカル開発で乗務記録簿 PDF を試す場合（VPS は ensure-libreoffice-env.sh が .env に書き込み）
# LIBREOFFICE_SOFFICE=C:\Program Files\LibreOffice\program\soffice.exe
# ヘッドレスで PDF が出ないときは headless ではなく gen（VPS デプロイ時に自動で入る）
# SAL_USE_VCLPLUGIN=gen
