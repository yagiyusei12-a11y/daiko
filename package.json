{
  "name": "daiko",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:web && tsc",
    "build:web": "npm --prefix web install && npm --prefix web run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "deploy:vps": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy-vps.ps1",
    "vps:apply-platform-env": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/vps-apply-platform-env.ps1",
    "extract:jommu-excel": "python scripts/extract_jommu_excel_spec.py",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/static": "^8.0.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.2.2",
    "nodemailer": "^7.0.3",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.3",
    "puppeteer-core": "^24.43.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
